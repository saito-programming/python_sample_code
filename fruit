function 落下物を作成する () {
    落下物 = game.createSprite(randint(0, 4), 0)
}
input.onButtonPressed(Button.A, function () {
    プレイヤー.change(LedSpriteProperty.X, -1)
})
function プレイヤーを作成する () {
    プレイヤー = game.createSprite(2, 4)
}
input.onButtonPressed(Button.B, function () {
    プレイヤー.change(LedSpriteProperty.X, 1)
})
let プレイヤー: game.LedSprite = null
let 落下物: game.LedSprite = null
プレイヤーを作成する()
落下物を作成する()
game.setScore(0)
basic.forever(function () {
    basic.pause(1000)
    落下物.change(LedSpriteProperty.Y, 1)
    if (落下物.get(LedSpriteProperty.Y) >= 4) {
        if (プレイヤー.isTouching(落下物)) {
            music.play(music.builtinPlayableSoundEffect(soundExpression.giggle), music.PlaybackMode.UntilDone)
            basic.pause(1000)
            落下物.delete()
            落下物を作成する()
        } else {
            game.gameOver()
        }
    }
})
